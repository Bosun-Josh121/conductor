# ── Network ──
STELLAR_NETWORK=stellar:testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Trustless Work ──
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com

# ── USDC Asset (Trustless Work testnet) ──
USDC_ASSET_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ASSET_CODE=USDC
USDC_DECIMALS=7

# ── AI ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Role Wallets ──
# Platform wallet — receives platform fees, signs releases
PLATFORM_SECRET_KEY=S...
# AI Verifier wallet — holds Approver role, signs milestone approvals
VERIFIER_SECRET_KEY=S...
# AI Arbiter wallet — holds Dispute Resolver role, resolves disputes
ARBITER_SECRET_KEY=S...

# ── Specialist Agent Wallets ──
STELLAR_ORACLE_SECRET_KEY=S...
WEB_INTEL_SECRET_KEY=S...
WEB_INTEL_V2_SECRET_KEY=S...
ANALYSIS_AGENT_SECRET_KEY=S...
REPORT_AGENT_SECRET_KEY=S...

# ── Ports ──
REGISTRY_PORT=4000
STELLAR_ORACLE_PORT=4001
WEB_INTEL_PORT=4002
WEB_INTEL_V2_PORT=4003
ANALYSIS_AGENT_PORT=4004
REPORT_AGENT_PORT=4005
ORCHESTRATOR_PORT=3000

# ── Registry ──
REGISTRY_URL=http://localhost:4000
DEFAULT_BUDGET=1.0

# ── Self URLs (update when deploying) ──
ORCHESTRATOR_SELF_URL=http://localhost:3000
STELLAR_ORACLE_SELF_URL=http://localhost:4001
WEB_INTEL_SELF_URL=http://localhost:4002
WEB_INTEL_V2_SELF_URL=http://localhost:4003
ANALYSIS_AGENT_SELF_URL=http://localhost:4004
REPORT_AGENT_SELF_URL=http://localhost:4005

# ── Plan approval timeout (ms). 0 = auto-approve immediately ──
PLAN_APPROVAL_TIMEOUT_MS=60000

# ── Sponsored wallet service ──
SPONSOR_SERVICE_URL=https://stellar-sponsored-agent-account.onrender.com
